# ============================================================================
# LUNA — .env.schema (Varlock)
# Schema for environment variables. AI agents read this, never your .env secrets.
# See: https://varlock.dev/env-spec/overview/
# ============================================================================

# @type=enum(development, staging, production)
NODE_ENV=development

# @type=port
PORT=3000

# @type=enum(fatal, error, warn, info, debug, trace)
LOG_LEVEL=info

# --- BASE DE DATOS (PostgreSQL) ---

# @type=string @required
DB_HOST=localhost

# @type=port
DB_PORT=5432

# @type=string
DB_NAME=luna

# @type=string
DB_USER=luna

# @sensitive @required
DB_PASSWORD=

# @type=number
DB_MAX_CONNECTIONS=20

# @type=number
DB_IDLE_TIMEOUT_MS=30000

# @type=number
DB_CONNECTION_TIMEOUT_MS=5000

# --- REDIS ---

# @type=string
REDIS_HOST=localhost

# @type=port
REDIS_PORT=6379

# @sensitive
REDIS_PASSWORD=

# @type=number
REDIS_DB=0

# @type=number
REDIS_MAX_RETRIES=3

# --- BULLMQ ---

# @type=number
BULLMQ_DEFAULT_ATTEMPTS=3

# @type=number
BULLMQ_BACKOFF_DELAY_MS=5000

# --- API KEYS (secretos) ---

# @sensitive @required
ANTHROPIC_API_KEY=

# @sensitive
GOOGLE_AI_API_KEY=

# --- GOOGLE OAUTH2 ---

# @sensitive
GOOGLE_CLIENT_ID=

# @sensitive
GOOGLE_CLIENT_SECRET=

# @type=url
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback

# @sensitive
GOOGLE_REFRESH_TOKEN=

# @type=string
GOOGLE_SHEET_ID=

# @type=boolean
GOOGLE_SHEET_SYNC_ENABLED=true

# --- WHATSAPP ---

# @type=boolean
WHATSAPP_ENABLED=true

# @type=string
WHATSAPP_AUTH_DIR=instance/wa-auth

# @type=number
WHATSAPP_RECONNECT_INTERVAL_MS=5000

# @type=number
WHATSAPP_MAX_RECONNECT_ATTEMPTS=10

# --- EMAIL ---

# @type=boolean
EMAIL_ENABLED=true

# @type=string @example=luna@example.com
EMAIL_FROM=

# @type=string
EMAIL_IMAP_HOST=imap.gmail.com

# @type=port
EMAIL_IMAP_PORT=993

# @type=string
EMAIL_SMTP_HOST=smtp.gmail.com

# @type=port
EMAIL_SMTP_PORT=465

# @type=number
EMAIL_POLL_INTERVAL_MS=60000

# --- LLM MODELS ---

# @type=string
LLM_CLASSIFY_MODEL=claude-haiku-4-5-20251001

# @type=string
LLM_CLASSIFY_PROVIDER=anthropic

# @type=string
LLM_RESPOND_MODEL=claude-sonnet-4-6-20250514

# @type=string
LLM_RESPOND_PROVIDER=anthropic

# @type=string
LLM_COMPLEX_MODEL=claude-opus-4-6-20250514

# @type=string
LLM_COMPLEX_PROVIDER=anthropic

# @type=string
LLM_TOOLS_MODEL=claude-haiku-4-5-20251001

# @type=string
LLM_TOOLS_PROVIDER=anthropic

# @type=string
LLM_COMPRESS_MODEL=claude-haiku-4-5-20251001

# @type=string
LLM_COMPRESS_PROVIDER=anthropic

# @type=string
LLM_PROACTIVE_MODEL=claude-sonnet-4-6-20250514

# @type=string
LLM_PROACTIVE_PROVIDER=anthropic

# --- LLM FALLBACK ---

# @type=string
LLM_FALLBACK_CLASSIFY_MODEL=gemini-3-flash

# @type=string
LLM_FALLBACK_CLASSIFY_PROVIDER=google

# @type=string
LLM_FALLBACK_RESPOND_MODEL=gemini-3-flash

# @type=string
LLM_FALLBACK_RESPOND_PROVIDER=google

# @type=string
LLM_FALLBACK_COMPLEX_MODEL=gemini-3-pro

# @type=string
LLM_FALLBACK_COMPLEX_PROVIDER=google

# --- LLM LIMITS ---

# @type=number
LLM_MAX_INPUT_TOKENS=4096

# @type=number
LLM_MAX_OUTPUT_TOKENS=2048

# @type=number
LLM_TEMPERATURE_CLASSIFY=0.1

# @type=number
LLM_TEMPERATURE_RESPOND=0.7

# @type=number
LLM_TEMPERATURE_COMPLEX=0.5

# @type=number
LLM_REQUEST_TIMEOUT_MS=30000

# --- LLM CIRCUIT BREAKER ---

# @type=number
LLM_CIRCUIT_BREAKER_FAILURES=5

# @type=number
LLM_CIRCUIT_BREAKER_WINDOW_MS=600000

# @type=number
LLM_CIRCUIT_BREAKER_COOLDOWN_MS=300000

# --- TOOLS ---

# @type=number
TOOLS_RETRY_BACKOFF_MS=1000

# @type=number
TOOLS_EXECUTION_TIMEOUT_MS=30000

# --- PIPELINE ---

# @type=number
PIPELINE_MAX_TOOL_CALLS_PER_TURN=5

# @type=number
PIPELINE_MAX_CONVERSATION_TURNS=50

# @type=number
PIPELINE_SESSION_TTL_MS=1800000

# --- FOLLOW-UP ---

# @type=boolean
FOLLOWUP_ENABLED=true

# @type=number
FOLLOWUP_DELAY_MINUTES=30

# @type=number
FOLLOWUP_MAX_ATTEMPTS=3

# @type=number
FOLLOWUP_COLD_AFTER_ATTEMPTS=3

# --- LEAD QUALIFICATION ---

# @type=string
QUALIFYING_CRITERIA_FILE=instance/qualifying.json

# @type=boolean
LEAD_SCORING_ENABLED=true

# --- BATCH ---

# @type=boolean
BATCH_ENABLED=true

# @type=string @example=0 2 * * *
BATCH_CRON=0 2 * * *

# @type=string
BATCH_TIMEZONE=America/Mexico_City

# --- MEDIA ---

# @type=string
MEDIA_STORAGE_DIR=instance/knowledge/media

# @type=number
MEDIA_MAX_FILE_SIZE_MB=16

# --- HEALTH CHECK ---

# @type=boolean
HEALTH_CHECK_ENABLED=true

# @type=port
HEALTH_CHECK_PORT=3001

# --- ADMIN UI ---

# @type=boolean
ADMIN_ENABLED=true

# @type=port
ADMIN_PORT=3002

# --- MODULES ---

# @type=boolean
MODULE_WHATSAPP=true

# @type=boolean
MODULE_EMAIL=true

# @type=boolean
MODULE_GOOGLE_SHEETS=true

# @type=boolean
MODULE_GOOGLE_CALENDAR=true

# @type=boolean
MODULE_BATCH=true

# @type=boolean
MODULE_FOLLOWUP=true

# @type=boolean
MODULE_WEB_SEARCH=false
