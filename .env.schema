# LUNA - Environment Variables Schema
# Format: env-spec (see https://varlock.dev/env-spec)
#
# @defaultRequired=infer @defaultSensitive=false
# ----------

# --- Base de datos ---
# @required
POSTGRES_HOST=localhost
# @type=port @required
POSTGRES_PORT=5432
# @required
POSTGRES_USER=luna
# @sensitive @required
POSTGRES_PASSWORD=luna_dev
# @required
POSTGRES_DB=luna

# --- Redis ---
# @required
REDIS_HOST=localhost
# @type=port @required
REDIS_PORT=6379
# @sensitive
REDIS_PASSWORD=

# --- API Keys (LLM Providers) ---
# @sensitive @required
ANTHROPIC_API_KEY=
# @sensitive @required
GOOGLE_AI_API_KEY=

# --- Admin UI ---
# @type=port
ADMIN_PORT=3001
# @sensitive
ADMIN_TOKEN=

# --- Server ---
SERVER_URL=

# --- General ---
# @required
NODE_ENV=development
LOG_LEVEL=info
