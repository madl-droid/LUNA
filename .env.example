# =============================================================================
# LUNA - Variables de Entorno (Secretos)
# Copiar a .env y llenar con valores reales
# =============================================================================

# --- Base de datos ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=luna
POSTGRES_PASSWORD=luna_dev
POSTGRES_DB=luna

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- API Keys (LLM Providers) ---
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# --- Admin UI ---
ADMIN_PORT=3001
ADMIN_TOKEN=

# --- Server ---
# Optional: auto-detected from machine IP if not set
SERVER_URL=

# --- General ---
NODE_ENV=development
LOG_LEVEL=info
