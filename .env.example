# ============================================================================
# LUNA — Configuración del agente
# Copia este archivo como .env y completa las vars marcadas REQUERIDO.
# Las vars OPCIONAL tienen default funcional y pueden omitirse.
# ============================================================================

# --- INFRAESTRUCTURA (REQUERIDO en producción, tienen defaults para dev) ---
NODE_ENV=development         # OPCIONAL (default: development)
PORT=3000                    # OPCIONAL (default: 3000)
LOG_LEVEL=info               # OPCIONAL (default: info) | debug | warn | error

# --- BASE DE DATOS PostgreSQL ---
DB_HOST=localhost             # REQUERIDO
DB_PORT=5432                  # OPCIONAL (default: 5432)
DB_NAME=luna                  # REQUERIDO
DB_USER=luna                  # REQUERIDO
DB_PASSWORD=luna_dev          # REQUERIDO
DB_MAX_CONNECTIONS=20         # OPCIONAL (default: 20)
DB_IDLE_TIMEOUT_MS=30000      # OPCIONAL (default: 30000)
DB_CONNECTION_TIMEOUT_MS=5000 # OPCIONAL (default: 5000)

# --- REDIS ---
REDIS_HOST=localhost           # REQUERIDO
REDIS_PORT=6379                # OPCIONAL (default: 6379)
REDIS_PASSWORD=                # OPCIONAL
REDIS_DB=0                     # OPCIONAL (default: 0)
REDIS_MAX_RETRIES=3            # OPCIONAL (default: 3)

# --- ENCRYPTION ---
# Opcional: si se omite, se auto-genera instance/config.key en primer arranque.
# CONFIG_ENCRYPTION_KEY=

# ===========================================================================
# PROVEEDORES LLM — al menos UNO es REQUERIDO para que el agente responda
# ===========================================================================

# Anthropic (Claude) — proveedor principal por defecto
ANTHROPIC_API_KEY=            # REQUERIDO si usas modelos Anthropic

# Google AI (Gemini) — proveedor de fallback y tareas de visión/embeddings
GOOGLE_AI_API_KEY=            # REQUERIDO si usas modelos Google / tareas de visión

# --- Modelos primarios (todos tienen default, cambiar solo si es necesario) ---
# OPCIONAL — los defaults usan los modelos más capaces disponibles
LLM_MAIN_MODEL=claude-sonnet-4-6-20260214     # conversación general
LLM_MAIN_PROVIDER=anthropic
LLM_COMPLEX_MODEL=claude-opus-4-6-20260210    # razonamiento profundo
LLM_COMPLEX_PROVIDER=anthropic
LLM_LOW_MODEL=claude-haiku-4-5-20251001       # saludos, ACKs
LLM_LOW_PROVIDER=anthropic
LLM_CRITICIZE_MODEL=gemini-2.5-pro            # quality gate
LLM_CRITICIZE_PROVIDER=google
LLM_MEDIA_MODEL=gemini-2.5-flash              # visión, audio, documentos
LLM_MEDIA_PROVIDER=google
LLM_COMPRESS_MODEL=claude-sonnet-4-6-20260214 # compresión de sesiones
LLM_COMPRESS_PROVIDER=anthropic

# --- Circuit breaker LLM ---
# OPCIONAL
LLM_CB_FAILURES=5             # fallas para abrir el breaker (default: 5)
LLM_CB_WINDOW_MS=600000       # ventana de conteo (default: 10 min)
LLM_CB_COOLDOWN_MS=300000     # tiempo DOWN antes de probar de nuevo (default: 5 min)

# ===========================================================================
# CANALES — configurar solo los canales que vayas a usar
# ===========================================================================

# --- WhatsApp (Baileys) ---
# REQUERIDO si el módulo whatsapp está activo
WHATSAPP_PHONE_NUMBER=        # ej: +5215512345678

# --- Twilio (Voz) ---
# REQUERIDO si el módulo twilio-voice está activo
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=          # ej: +15005550006

# --- Google OAuth2 (Gmail, Calendar, Drive, Sheets, Docs, Slides) ---
# REQUERIDO si cualquier módulo Google está activo
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/console/api/google-apps/oauth2callback
GOOGLE_REFRESH_TOKEN=         # se obtiene via /console → Google Apps → Conectar
GOOGLE_ENABLED_SERVICES=drive,sheets,docs,slides,calendar  # OPCIONAL

# ===========================================================================
# MÓDULO PIPELINE / ENGINE
# ===========================================================================
# OPCIONAL — todos tienen defaults funcionales

ENGINE_MAX_CONCURRENT_PIPELINES=50   # (default: 50)
ENGINE_MAX_QUEUE_SIZE=200             # (default: 200)
SESSION_TTL_MS=1800000                # ventana de reapertura de sesión: 30 min

# ===========================================================================
# BASE DE CONOCIMIENTO
# ===========================================================================
# OPCIONAL

KNOWLEDGE_DIR=instance/knowledge           # (default: instance/knowledge)
KNOWLEDGE_EMBEDDING_ENABLED=true           # habilitar vectorización con Google AI
# GOOGLE_AI_API_KEY debe estar configurada arriba para que funcionen los embeddings

# ===========================================================================
# INTEGRACIONES EXTERNAS (solo si los módulos correspondientes están activos)
# ===========================================================================

# --- Freshdesk KB ---
FRESHDESK_DOMAIN=miempresa.freshdesk.com  # REQUERIDO para módulo freshdesk
FRESHDESK_API_KEY=                         # REQUERIDO para módulo freshdesk

# --- Medilink / HealthAtom ---
MEDILINK_API_URL=                          # REQUERIDO para módulo medilink
MEDILINK_API_KEY=                          # REQUERIDO para módulo medilink
