# ============================================================================
# LUNA — Archivo central de configuracion
# Copia este archivo como .env y ajusta los valores a tu instancia.
# TODAS las variables configurables del sistema se definen aqui.
# ============================================================================

# --- NODE ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# --- BASE DE DATOS (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=luna
DB_USER=luna
DB_PASSWORD=luna_dev
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000

# --- REDIS ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_RETRIES=3

# --- ENCRYPTION (config-store) ---
# Opcional: si se omite, se auto-genera instance/config.key en primer arranque.
# CONFIG_ENCRYPTION_KEY=

# --- API KEYS (secretos) ---
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# --- GOOGLE API (OAuth2 + Drive + Sheets + Docs + Slides + Calendar) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/console/api/google-apps/oauth2callback
GOOGLE_REFRESH_TOKEN=
GOOGLE_ENABLED_SERVICES=drive,sheets,docs,slides,calendar
GOOGLE_TOKEN_REFRESH_BUFFER_MS=300000
GOOGLE_API_TIMEOUT_MS=30000
GOOGLE_API_RETRY_MAX=2

# --- GOOGLE SHEETS (legacy sync) ---
GOOGLE_SHEET_ID=
GOOGLE_SHEET_SYNC_ENABLED=true

# --- WHATSAPP (Baileys) ---
WHATSAPP_ENABLED=true
WHATSAPP_AUTH_DIR=instance/wa-auth
WHATSAPP_PHONE_NUMBER=
TWILIO_PHONE_NUMBER=

# --- EMAIL (Gmail API) ---
EMAIL_POLL_INTERVAL_MS=60000
EMAIL_MAX_ATTACHMENT_SIZE_MB=16
EMAIL_NOREPLY_ADDRESSES=
EMAIL_NOREPLY_PATTERNS=
EMAIL_PROCESS_LABELS=INBOX
EMAIL_SKIP_LABELS=SPAM,TRASH
EMAIL_AUTO_MARK_READ=true
EMAIL_INCLUDE_SIGNATURE=true
EMAIL_MAX_HISTORY_FETCH=20
EMAIL_ACCOUNT_TYPE=workspace
EMAIL_RATE_LIMIT_PER_HOUR=0
EMAIL_RATE_LIMIT_PER_DAY=0
EMAIL_ALWAYS_CC=
EMAIL_CUSTOM_LABELS=[]
# OAuth standalone (solo si el módulo Google API NO está activo)
# Si google-apps está activo, email comparte su OAuth automáticamente
# GOOGLE_CLIENT_ID=           (reusar las mismas vars o configurar aparte)
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/console/api/gmail/oauth2callback
# GOOGLE_REFRESH_TOKEN=
# GOOGLE_TOKEN_REFRESH_BUFFER_MS=300000

# --- LLM: MODELOS ---
LLM_CLASSIFY_MODEL=claude-haiku-4-5-20251001
LLM_CLASSIFY_PROVIDER=anthropic
LLM_RESPOND_MODEL=claude-sonnet-4-5-20250929
LLM_RESPOND_PROVIDER=anthropic
LLM_COMPLEX_MODEL=claude-opus-4-5-20251101
LLM_COMPLEX_PROVIDER=anthropic
LLM_TOOLS_MODEL=claude-haiku-4-5-20251001
LLM_TOOLS_PROVIDER=anthropic
LLM_COMPRESS_MODEL=claude-haiku-4-5-20251001
LLM_PROACTIVE_MODEL=claude-sonnet-4-5-20250929
LLM_PROACTIVE_PROVIDER=anthropic

# --- LLM: FALLBACK ---
LLM_FALLBACK_CLASSIFY_MODEL=gemini-2.5-flash
LLM_FALLBACK_CLASSIFY_PROVIDER=google
LLM_FALLBACK_RESPOND_MODEL=gemini-2.5-flash
LLM_FALLBACK_RESPOND_PROVIDER=google
LLM_FALLBACK_COMPLEX_MODEL=gemini-2.5-pro
LLM_FALLBACK_COMPLEX_PROVIDER=google

# --- LLM: LIMITES Y TOKENS ---
LLM_MAX_INPUT_TOKENS=4096
LLM_MAX_OUTPUT_TOKENS=2048
LLM_TEMPERATURE_CLASSIFY=0.1
LLM_TEMPERATURE_RESPOND=0.7
LLM_TEMPERATURE_COMPLEX=0.5
LLM_REQUEST_TIMEOUT_MS=30000

# --- LLM: CIRCUIT BREAKER ---
LLM_CIRCUIT_BREAKER_FAILURES=5
LLM_CIRCUIT_BREAKER_WINDOW_MS=600000
LLM_CIRCUIT_BREAKER_COOLDOWN_MS=300000

# --- TOOLS (herramientas del agente) ---
TOOLS_RETRY_BACKOFF_S=1
TOOLS_EXECUTION_TIMEOUT_S=30

# --- PIPELINE ---
PIPELINE_MAX_TOOL_CALLS_PER_TURN=5
PIPELINE_MAX_CONVERSATION_TURNS=50
PIPELINE_SESSION_TTL_MS=1800000
PIPELINE_MAX_REPLAN_ATTEMPTS=2

# --- CONCURRENCIA ---
ENGINE_MAX_CONCURRENT_PIPELINES=50
ENGINE_MAX_QUEUE_SIZE=200
ENGINE_MAX_CONCURRENT_STEPS=5
ENGINE_BACKPRESSURE_MESSAGE=Estamos atendiendo muchos clientes en este momento. Te responderemos pronto.
ENGINE_COMPOSE_RETRIES_PER_PROVIDER=1

# --- KNOWLEDGE ---
KNOWLEDGE_DIR=instance/knowledge

# --- FOLLOW-UP / PROACTIVE ---
FOLLOWUP_ENABLED=true
FOLLOWUP_DELAY_MINUTES=30
FOLLOWUP_MAX_ATTEMPTS=3
FOLLOWUP_COLD_AFTER_ATTEMPTS=3

# --- BATCH NOCTURNO ---
BATCH_ENABLED=true
BATCH_CRON=0 2 * * *
BATCH_TIMEZONE=America/Mexico_City

# --- HEALTH CHECK ---
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PORT=3001

# --- USUARIOS Y PERMISOS ---
USER_TYPE_CACHE_TTL=43200
USER_LISTS_ENABLED=true
SHEET_SYNC_INTERVAL=3600000

# --- CONSOLE ---
CONSOLE_ENABLED=true

# --- MODULOS ACTIVOS ---
MODULE_WHATSAPP=true
MODULE_EMAIL=true
MODULE_GOOGLE_SHEETS=true
MODULE_GOOGLE_CALENDAR=true
MODULE_BATCH=true
MODULE_FOLLOWUP=true
MODULE_WEB_SEARCH=false

# --- PROMPTS ---
TTS_ENABLED=false
PROMPTS_MAX_SYSTEM_PROMPT_TOKENS=4000
PROMPTS_MAX_COMPRESSION_SUMMARY_TOKENS=1000

# --- FRESHDESK KNOWLEDGE BASE ---
FRESHDESK_DOMAIN=miempresa.freshdesk.com
FRESHDESK_API_KEY=
FRESHDESK_CACHE_TTL_HOURS=24
FRESHDESK_CATEGORIES=
