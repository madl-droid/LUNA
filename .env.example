# ============================================================================
# LUNA — Archivo central de configuracion
# Copia este archivo como .env y ajusta los valores a tu instancia.
# TODAS las variables configurables del sistema se definen aqui.
# ============================================================================

# --- NODE ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# --- BASE DE DATOS (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=luna
DB_USER=luna
DB_PASSWORD=luna_dev
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000

# --- REDIS ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_RETRIES=3

# --- BULLMQ (colas de trabajo) ---
BULLMQ_DEFAULT_ATTEMPTS=3
BULLMQ_BACKOFF_DELAY_MS=5000

# --- API KEYS (secretos) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=

# --- GOOGLE OAUTH2 (Gmail, Calendar, Sheets) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback
GOOGLE_REFRESH_TOKEN=

# --- GOOGLE SHEETS ---
GOOGLE_SHEET_ID=
GOOGLE_SHEET_SYNC_ENABLED=true

# --- WHATSAPP (Baileys) ---
WHATSAPP_ENABLED=true
WHATSAPP_AUTH_DIR=instance/wa-auth
WHATSAPP_RECONNECT_INTERVAL_MS=5000
WHATSAPP_MAX_RECONNECT_ATTEMPTS=10
WHATSAPP_PHONE_NUMBER=
TWILIO_PHONE_NUMBER=

# --- EMAIL (Nodemailer / Gmail) ---
EMAIL_ENABLED=true
EMAIL_FROM=
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=465
EMAIL_POLL_INTERVAL_MS=60000

# --- LLM: MODELOS ---
LLM_CLASSIFY_MODEL=claude-haiku-4-5-20251001
LLM_CLASSIFY_PROVIDER=anthropic
LLM_RESPOND_MODEL=claude-sonnet-4-5-20250929
LLM_RESPOND_PROVIDER=anthropic
LLM_COMPLEX_MODEL=claude-opus-4-5-20251101
LLM_COMPLEX_PROVIDER=anthropic
LLM_TOOLS_MODEL=claude-haiku-4-5-20251001
LLM_TOOLS_PROVIDER=anthropic
LLM_COMPRESS_MODEL=claude-haiku-4-5-20251001
LLM_COMPRESS_PROVIDER=anthropic
LLM_PROACTIVE_MODEL=claude-sonnet-4-5-20250929
LLM_PROACTIVE_PROVIDER=anthropic

# --- LLM: FALLBACK ---
LLM_FALLBACK_CLASSIFY_MODEL=gemini-2.5-flash
LLM_FALLBACK_CLASSIFY_PROVIDER=google
LLM_FALLBACK_RESPOND_MODEL=gemini-2.5-flash
LLM_FALLBACK_RESPOND_PROVIDER=google
LLM_FALLBACK_COMPLEX_MODEL=gemini-2.5-pro
LLM_FALLBACK_COMPLEX_PROVIDER=google

# --- LLM: LIMITES Y TOKENS ---
LLM_MAX_INPUT_TOKENS=4096
LLM_MAX_OUTPUT_TOKENS=2048
LLM_TEMPERATURE_CLASSIFY=0.1
LLM_TEMPERATURE_RESPOND=0.7
LLM_TEMPERATURE_COMPLEX=0.5
LLM_REQUEST_TIMEOUT_MS=30000

# --- LLM: CIRCUIT BREAKER ---
LLM_CIRCUIT_BREAKER_FAILURES=5
LLM_CIRCUIT_BREAKER_WINDOW_MS=600000
LLM_CIRCUIT_BREAKER_COOLDOWN_MS=300000

# --- TOOLS (herramientas del agente) ---
TOOLS_RETRY_BACKOFF_MS=1000
TOOLS_EXECUTION_TIMEOUT_MS=30000

# --- PIPELINE ---
PIPELINE_MAX_TOOL_CALLS_PER_TURN=5
PIPELINE_MAX_CONVERSATION_TURNS=50
PIPELINE_SESSION_TTL_MS=1800000

# --- FOLLOW-UP / PROACTIVE ---
FOLLOWUP_ENABLED=true
FOLLOWUP_DELAY_MINUTES=30
FOLLOWUP_MAX_ATTEMPTS=3
FOLLOWUP_COLD_AFTER_ATTEMPTS=3

# --- CALIFICACION DE LEADS ---
QUALIFYING_CRITERIA_FILE=instance/qualifying.json
LEAD_SCORING_ENABLED=true

# --- BATCH NOCTURNO ---
BATCH_ENABLED=true
BATCH_CRON=0 2 * * *
BATCH_TIMEZONE=America/Mexico_City

# --- MEDIA ---
MEDIA_STORAGE_DIR=instance/knowledge/media
MEDIA_MAX_FILE_SIZE_MB=16

# --- HEALTH CHECK ---
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PORT=3001

# --- OFICINA ---
OFICINA_ENABLED=true

# --- MODULOS ACTIVOS ---
MODULE_WHATSAPP=true
MODULE_EMAIL=true
MODULE_GOOGLE_SHEETS=true
MODULE_GOOGLE_CALENDAR=true
MODULE_BATCH=true
MODULE_FOLLOWUP=true
MODULE_WEB_SEARCH=false
