# ============================================================================
# LUNA — Variables de entorno para deploy en servidor
# Copia este archivo como .env en la carpeta de deploy y ajusta los valores.
# ============================================================================

# --- DOMINIO (Traefik lo usa para rutear y generar SSL) ---
DOMAIN=luna.example.com

# --- APP ---
NODE_ENV=production
PORT=3000
APP_PORT=3000
LOG_LEVEL=info

# --- BASE DE DATOS ---
DB_HOST=postgres
DB_PORT=5432
DB_NAME=luna
DB_USER=luna
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000

# --- REDIS ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_RETRIES=3

# --- API KEYS ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=

# --- GOOGLE OAUTH2 ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_REFRESH_TOKEN=
GOOGLE_SHEET_ID=
GOOGLE_SHEET_SYNC_ENABLED=false

# --- WHATSAPP ---
WHATSAPP_ENABLED=false
WHATSAPP_AUTH_DIR=instance/wa-auth

# --- EMAIL ---
EMAIL_ENABLED=false
EMAIL_FROM=

# --- LLM MODELOS (ver CLAUDE.md para tabla completa) ---
LLM_CLASSIFY_MODEL=claude-haiku-4-5-20251001
LLM_RESPOND_MODEL=claude-sonnet-4-6-20250514
LLM_COMPLEX_MODEL=claude-opus-4-6-20250514

# --- HEALTH CHECK ---
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PORT=3001
