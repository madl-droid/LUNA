      {
        "type": "send_info",
        "max_due_hours": 4,
        "requires_tool": null,
        "auto_cancel_hours": 24
      },
      {
        "type": "follow_up",
        "max_due_hours": 72,
        "requires_tool": null,
        "auto_cancel_hours": 96
      },
      {
        "type": "check_availability",
        "max_due_hours": 2,
