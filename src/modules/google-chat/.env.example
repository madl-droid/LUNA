# Google Chat — Service Account auth
GOOGLE_CHAT_SERVICE_ACCOUNT_KEY=     # JSON content or path to .json file
GOOGLE_CHAT_WEBHOOK_TOKEN=           # Optional: verification token for webhooks

# Message limits
GOOGLE_CHAT_MAX_MESSAGE_LENGTH=4096

# Room behavior
GOOGLE_CHAT_DM_ONLY=false            # Only process DMs, ignore rooms/spaces
GOOGLE_CHAT_REQUIRE_MENTION=true     # In rooms, require @mention to respond
GOOGLE_CHAT_SPACE_WHITELIST=         # Comma-separated allowed space names (empty=all)

# Threads
GOOGLE_CHAT_REPLY_IN_THREAD=true     # Reply in same thread
GOOGLE_CHAT_PROCESS_THREADS=true     # Process threaded messages

# Send retries
GOOGLE_CHAT_MAX_RETRIES=3            # Retries on transient send failures
GOOGLE_CHAT_RETRY_DELAY_MS=1000      # Base delay between retries (ms)

# Card clicks
GOOGLE_CHAT_PROCESS_CARD_CLICKS=false
GOOGLE_CHAT_CARD_CLICK_ACTION=respond  # respond | log | ignore

# Naturalness (aviso/ack)
GOOGLE_CHAT_AVISO_TRIGGER_MS=3000
GOOGLE_CHAT_AVISO_HOLD_MS=2000
GOOGLE_CHAT_AVISO_MESSAGE=Un momento, estoy revisando eso...

# Rate limits
GOOGLE_CHAT_RATE_LIMIT_HOUR=30
GOOGLE_CHAT_RATE_LIMIT_DAY=200

# Session
GOOGLE_CHAT_SESSION_TIMEOUT_HOURS=24
GOOGLE_CHAT_BATCH_WAIT_SECONDS=0     # 0 = no batching
GOOGLE_CHAT_PRECLOSE_FOLLOWUP_HOURS=1
GOOGLE_CHAT_PRECLOSE_MESSAGE=¿Sigues ahí? Tu sesión se cerrará pronto por inactividad. Si necesitas algo más, escríbeme.
