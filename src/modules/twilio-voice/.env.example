# ── Twilio credentials ──
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1234567890

# ── Gemini Live — API & model ──
VOICE_GOOGLE_API_KEY=
VOICE_GEMINI_MODEL=gemini-2.5-flash
VOICE_GEMINI_VOICE=Kore
VOICE_GEMINI_LANGUAGE=

# ── Gemini Live — generation config ──
VOICE_GEMINI_TEMPERATURE=0.7
VOICE_GEMINI_TOP_P=0.95
VOICE_GEMINI_TOP_K=40
VOICE_GEMINI_MAX_OUTPUT_TOKENS=1024

# ── Gemini Live — VAD nativo ──
VOICE_VAD_START_SENSITIVITY=START_SENSITIVITY_HIGH
VOICE_VAD_END_SENSITIVITY=END_SENSITIVITY_HIGH
VOICE_VAD_PREFIX_PADDING_MS=20
VOICE_VAD_SILENCE_DURATION_MS=500
VOICE_BARGE_IN_ENABLED=true
VOICE_GEMINI_CONNECTION_TIMEOUT_MS=15000

# ── Silence detector local ──
VOICE_SILENCE_RMS_THRESHOLD=200

# ── Call behavior ──
VOICE_PREVIEW_TEXT=Hola, soy tu asistente virtual. ¿En qué puedo ayudarte hoy?
VOICE_ANSWER_DELAY_RINGS=2
VOICE_SILENCE_TIMEOUT_MS=10000
VOICE_SILENCE_MESSAGE=¿Sigues ahí?
VOICE_GREETING_INBOUND=Hola, gracias por llamar. ¿En qué puedo ayudarte?
VOICE_GREETING_OUTBOUND=Hola, te llamo de parte de la empresa. ¿Es un buen momento para hablar?
VOICE_FILLER_MESSAGE=Dame un momento, estoy revisando eso...
VOICE_GOODBYE_TIMEOUT_MS=5000
VOICE_MAX_CALL_DURATION_MS=1800000
VOICE_MAX_CONCURRENT_CALLS=5
VOICE_ENABLED=true

# ── Channel runtime config (engine integration) ──
VOICE_RATE_LIMIT_HOUR=0
VOICE_RATE_LIMIT_DAY=0
VOICE_SESSION_TIMEOUT_HOURS=1
