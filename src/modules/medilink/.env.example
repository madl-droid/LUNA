# ─── Medilink (HealthAtom) Integration ────────────────

# API Connection
MEDILINK_API_TOKEN=              # Token from Medilink (Admin → API Configuration)
MEDILINK_BASE_URL=https://api.medilink2.healthatom.com/api/v1

# Webhook Security
MEDILINK_WEBHOOK_PUBLIC_KEY=     # Public key for webhook verification (header "token")
MEDILINK_WEBHOOK_PRIVATE_KEY=    # Private key for HMAC signature verification

# Defaults
MEDILINK_DEFAULT_BRANCH_ID=      # Default branch/sucursal ID
MEDILINK_DEFAULT_DURATION_MIN=30 # Default appointment duration (minutes)
MEDILINK_DEFAULT_STATUS_ID=      # Status ID for new appointments

# Rate Limiting
MEDILINK_RATE_LIMIT_RPM=20       # API requests per minute (max 20)
MEDILINK_API_TIMEOUT_MS=15000    # HTTP timeout (ms)

# Cache
MEDILINK_REFERENCE_REFRESH_DAYS=30       # Auto-refresh reference data (days)
MEDILINK_AVAILABILITY_CACHE_TTL_MS=600000 # Availability cache TTL (10 min)

# Follow-up Sequence
MEDILINK_FOLLOWUP_ENABLED=true
MEDILINK_FOLLOWUP_TOUCH1_DAYS_BEFORE=7        # Touch 1: call days before appointment
MEDILINK_FOLLOWUP_FALLBACK_A_HOURS=3          # Fallback A: hours after failed call
MEDILINK_FOLLOWUP_FALLBACK_B_DAYS_BEFORE=5    # Fallback B: 2nd call days before
MEDILINK_FOLLOWUP_TOUCH3_HOURS_BEFORE=24      # Touch 3: prep instructions hours before
MEDILINK_FOLLOWUP_TOUCH4_HOURS_BEFORE=3       # Touch 4: short reminder hours before
MEDILINK_FOLLOWUP_NOSHOW_HOURS_AFTER=3        # No-show: hours after appointment
MEDILINK_FOLLOWUP_REACTIVATION_DAYS=15        # Reactivation: days after archiving

# Security
MEDILINK_REQUIRE_DOCUMENT_FOR_DEBTS=true  # Require document verification for debt details
MEDILINK_AUTO_LINK_SINGLE_MATCH=true      # Auto-link when phone matches exactly one patient

# Health Check
MEDILINK_HEALTH_CHECK_INTERVAL_MS=21600000 # Health check interval (6 hours)
