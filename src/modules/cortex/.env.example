# Cortex — Sistema nervioso de LUNA
# Feature: Reflex (monitoreo y alertas en tiempo real)

CORTEX_REFLEX_ENABLED=true

# Canales de alerta (separados por coma): telegram, whatsapp, email
CORTEX_REFLEX_CHANNELS=telegram

# Telegram Bot (canal independiente recomendado)
CORTEX_TELEGRAM_BOT_TOKEN=
CORTEX_TELEGRAM_CHAT_ID=

# Umbrales
CORTEX_REFLEX_MEM_THRESHOLD=80       # % memoria para alerta crítica
CORTEX_REFLEX_DISK_THRESHOLD=90      # % disco para alerta crítica
CORTEX_REFLEX_LATENCY_THRESHOLD_MS=10000  # latencia pipeline p95

# Intervalos de evaluación (ms)
CORTEX_REFLEX_INFRA_INTERVAL_MS=60000      # PG + Redis cada 60s
CORTEX_REFLEX_RESOURCE_INTERVAL_MS=300000  # RAM, CPU, disco cada 5 min
CORTEX_REFLEX_TRENDS_INTERVAL_MS=900000    # métricas agregadas cada 15 min
CORTEX_REFLEX_FLUSH_INTERVAL_MS=60000      # flush contadores a Redis cada 60s

# Alertas
CORTEX_REFLEX_LOG_BUFFER_SIZE=100          # ring buffer de logs
CORTEX_REFLEX_DEDUP_WINDOW_MS=300000       # 5 min deduplicación
CORTEX_REFLEX_ESCALATION_MS=900000         # 15 min para escalar DEGRADADO → CRÍTICO

# Silencio programado (alertas INFO se silencian, CRÍTICO siempre pasa)
CORTEX_REFLEX_SILENCE_START=23:00
CORTEX_REFLEX_SILENCE_END=07:00
