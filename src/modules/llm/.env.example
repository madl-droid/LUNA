# ═══════════════════════════════════════════
# LLM Module — Gateway unificado
# ═══════════════════════════════════════════

# --- Provider API Keys ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_AI_API_KEY=AIza...

# --- Per-capability API Key Overrides (opcional) ---
# Usar API keys diferentes para tareas específicas (ej: billing separado para visión)
# LLM_VISION_API_KEY=
# LLM_STT_API_KEY=
# LLM_IMAGE_GEN_API_KEY=

# --- Circuit Breaker ---
# Fallos para marcar provider como DOWN (default: 5)
# LLM_CB_FAILURE_THRESHOLD=5
# Ventana de tiempo para contar fallos en ms (default: 600000 = 10 min)
# LLM_CB_WINDOW_MS=600000
# Tiempo que el provider permanece DOWN antes de probar recovery en ms (default: 300000 = 5 min)
# LLM_CB_RECOVERY_MS=300000
# Requests de prueba en half-open (default: 1)
# LLM_CB_HALF_OPEN_MAX=1

# --- Retry ---
# Reintentos antes de fallar (default: 2)
# LLM_RETRY_MAX=2
# Backoff base en ms — se multiplica exponencialmente (default: 1000)
# LLM_RETRY_BACKOFF_MS=1000

# --- Timeouts por Provider (ms) ---
# LLM_TIMEOUT_ANTHROPIC_MS=30000
# LLM_TIMEOUT_GOOGLE_MS=30000
# LLM_TIMEOUT_OPENAI_MS=30000

# --- Rate Limits por Provider (0 = sin límite) ---
# LLM_RPM_ANTHROPIC=0
# LLM_RPM_GOOGLE=0
# LLM_RPM_OPENAI=0
# LLM_TPM_ANTHROPIC=0
# LLM_TPM_GOOGLE=0
# LLM_TPM_OPENAI=0

# --- Presupuesto (USD, 0 = sin límite) ---
# LLM_DAILY_BUDGET_USD=0
# LLM_MONTHLY_BUDGET_USD=0

# --- Usage Tracking ---
# LLM_USAGE_ENABLED=true
# LLM_USAGE_RETENTION_DAYS=90

# --- Task Routing (JSON, opcional — usa defaults si no se especifica) ---
# Formato: {"provider":"anthropic","model":"claude-haiku-4-5-20251001","temperature":0.1}
# LLM_ROUTE_CLASSIFY=
# LLM_ROUTE_RESPOND=
# LLM_ROUTE_COMPLEX=
# LLM_ROUTE_TOOLS=
# LLM_ROUTE_PROACTIVE=

# --- Fallback Chain ---
# Orden de providers para fallback, separados por coma
# LLM_FALLBACK_CHAIN=anthropic,google,openai
